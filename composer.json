{
    "name": "jah/jas",
    "description": "JAS — JAH Action Script PHP: runtime de acciones, eventos, objetos activos y estado persistente en PHP.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1.56"
    },
    "suggest": {
        "ext-pcntl": "Necesaria para workers y pruebas TCP con procesos.",
        "ext-sodium": "Necesaria para identidad y transporte cifrado del clúster."
    },
    "autoload": {
        "psr-4": {
            "Jah\\JAS\\": "src/JAS/",
            "Jah\\DataCore\\": "src/DataCore/",
            "Jah\\Core\\": "app/core/",
            "Jah\\Memory\\": "app/memory/",
            "Jah\\Cache\\": "app/cache/",
            "Jah\\Security\\": "app/security/",
            "Jah\\Http\\": "app/http/"
        },
        "files": [
            "app/config/environment.php"
        ]
    },
    "bin": ["bin/jas"],
    "scripts": {
        "test": "@php tests/run_all.php",
        "health": "@php bin/jas health",
        "lint": "find app src php_actionscript_php_doc public tests -type f -name '*.php' -exec php -l {} ;",
        "static": "@php vendor/bin/phpstan analyse -c phpstan.neon.dist --no-progress --debug",
        "verify": ["@static", "@test"]
    },
    "config": {
        "sort-packages": true
    }
}
